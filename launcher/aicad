    cp "$AICAD_DIR/theme/aicad.qss" "$FREECAD_APP/Contents/Resources/share/Gui/Stylesheets/" 2>/dev/null
fi

# Install addon if needed
ADDON_DIR="$HOME/Library/Application Support/FreeCAD/Mod/FreecadAITool"
if [ -d "$AICAD_DIR/addon" ] && [ -d "$ADDON_DIR" ]; then
    cp "$AICAD_DIR/addon/"*.py "$ADDON_DIR/" 2>/dev/null
fi

